{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/v1/*", "/assets/*", "/*.js", "/*.css", "/*.ico", "/*.png", "/*.svg"]
  },
  "routes": [
    {
      "route": "/v1/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff"
  }
}
