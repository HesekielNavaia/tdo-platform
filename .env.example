# TDO Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tdo_dev

# Blob storage (MinIO for local, Azure Blob for cloud)
BLOB_ENDPOINT=http://localhost:9000
BLOB_ACCOUNT_NAME=minioadmin
BLOB_ACCOUNT_KEY=minioadmin
BLOB_CONTAINER_RAW=tdo-raw
BLOB_CONTAINER_HOT=tdo-harmonised

# Embedding endpoint (HuggingFace TEI locally, Azure AI Foundry in cloud)
EMBEDDING_ENDPOINT=http://localhost:8080
EMBEDDING_DIM=1024
# EMBEDDING_API_KEY=<azure-ai-foundry-key>  # Leave blank for local TEI

# LLM endpoint for harmonisation (Ollama locally, Phi-4 in cloud)
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=phi4
# LLM_API_KEY=<azure-ai-foundry-key>  # Leave blank for local Ollama

# Azure OpenAI fallback (optional — used when confidence < 0.3)
# OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com/
# OPENAI_API_KEY=<key>
# OPENAI_MODEL=gpt-4o

# API authentication
TDO_API_KEYS=dev-key-123
TDO_ELEVATED_KEYS=admin-key-456

# Portal rate limits (requests per second)
STATFIN_RATE_LIMIT_RPS=1.0
WORLDBANK_RATE_LIMIT_RPS=1.0
EUROSTAT_RATE_LIMIT_RPS=2.0
OECD_RATE_LIMIT_RPS=1.0
UNDATA_RATE_LIMIT_RPS=1.0

# Pipeline settings
HARMONISER_VERSION=0.1.0
REVIEW_THRESHOLD=0.6
LOW_CONFIDENCE_THRESHOLD=0.3
